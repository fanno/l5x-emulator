<Routines>
<Routine Name="IFTest" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[ST._AND := 0;]]>
</Line>
<Line Number="1">
<![CDATA[ST._OR := 0;]]>
</Line>
<Line Number="2">
<![CDATA[ST.string:='';]]>
</Line>
<Line Number="3">
<![CDATA[]]>
</Line>
<Line Number="4">
<![CDATA[if ST.test1 AND ST.test2 then]]>
</Line>
<Line Number="5">
<![CDATA[	ST._AND := 1;]]>
</Line>
<Line Number="6">
<![CDATA[elsif ST.test1 OR ST.test2 then]]>
</Line>
<Line Number="7">
<![CDATA[	ST._OR := 1;]]>
</Line>
<Line Number="8">
<![CDATA[else]]>
</Line>
<Line Number="9">
<![CDATA[	ST.string:='All OFF';]]>
</Line>
<Line Number="10">
<![CDATA[end_if;]]>
</Line>
<Line Number="11">
<![CDATA[]]>
</Line>
<Line Number="12">
<![CDATA[case ST._CASE OF	]]>
</Line>
<Line Number="13">
<![CDATA[	1:]]>
</Line>
<Line Number="14">
<![CDATA[		ST.stringCase:='1';]]>
</Line>
<Line Number="15">
<![CDATA[	2,3,7..8,10 .. 15:]]>
</Line>
<Line Number="16">
<![CDATA[		ST.stringCase:='2,3,7..8,10 .. 15';		]]>
</Line>
<Line Number="17">
<![CDATA[	else]]>
</Line>
<Line Number="18">
<![CDATA[		ST.stringCase:='else';]]>
</Line>
<Line Number="19">
<![CDATA[end_case;]]>
</Line>
<Line Number="20">
<![CDATA[]]>
</Line>
<Line Number="21">
<![CDATA[while ST.while_test Do]]>
</Line>
<Line Number="22">
<![CDATA[	ST.while_test := 0;]]>
</Line>
<Line Number="23">
<![CDATA[end_while;]]>
</Line>
<Line Number="24">
<![CDATA[]]>
</Line>
<Line Number="25">
<![CDATA[FOR ST.i:= 0 TO 9 By 1 Do]]>
</Line>
<Line Number="26">
<![CDATA[	ST._FOR[ST.i] := ST.i;]]>
</Line>
<Line Number="27">
<![CDATA[end_for;]]>
</Line>
<Line Number="28">
<![CDATA[]]>
</Line>
<Line Number="29">
<![CDATA[sttimer.PRE := 10000;]]>
</Line>
<Line Number="30">
<![CDATA[TONR(ST.Timer );]]>
</Line>
<Line Number="31">
<![CDATA[ST.Timer.TimerEnable := ST.Timer_Run;]]>
</Line>
<Line Number="32">
<![CDATA[ST.Timer.Reset := not ST.Timer.TimerEnable;]]>
</Line>
</STContent>
</Routine>
<Routine Name="main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[JSR(IFTest,0);]]>
</Text>
</Rung>
</RLLContent>
